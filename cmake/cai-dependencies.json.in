{
  "schemaVersion": 1,
  "project": "cai",
  "version": "@PROJECT_VERSION@",
  "targetId": "@CAI_TARGET_ID@",
  "dependencyMode": "@CAI_RESOLVED_DEPENDENCY_MODE@",
  "dependencies": [
    {
      "name": "c.pkt.systems",
      "version": "@CAI_C_PKT_SYSTEMS_VERSION@",
      "targetId": "@CAI_TARGET_ID@",
      "sourceSystem": "github-release",
      "sourceUrl": "@CAI_C_PKT_SYSTEMS_URL_FOR_PACKAGE@",
      "sha256": "@CAI_C_PKT_SYSTEMS_SHA256_FOR_PACKAGE@",
      "archiveName": "@CAI_C_PKT_SYSTEMS_ARCHIVE_NAME_FOR_PACKAGE@",
      "licenseIdentifier": "NOASSERTION",
      "bundled": false,
      "installRole": "external-static-consumer-sdk"
    },
    {
      "name": "lonejson",
      "version": "@CAI_LONEJSON_VERSION@",
      "targetId": "@CAI_TARGET_ID@",
      "sourceSystem": "github-release",
      "sourceUrl": "@CAI_LONEJSON_PKG_URL_FOR_PACKAGE@",
      "sha256": "@CAI_LONEJSON_PKG_SHA256_FOR_PACKAGE@",
      "archiveName": "@CAI_LONEJSON_ARCHIVE_NAME_FOR_PACKAGE@",
      "licenseIdentifier": "NOASSERTION",
      "bundled": false,
      "installRole": "public-link-interface"
    }
  ]
}
