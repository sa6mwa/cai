prefix=${pcfiledir}/../..
exec_prefix=${prefix}
libdir=${exec_prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@
c_pkt_systems_version=@CAI_C_PKT_SYSTEMS_VERSION@
c_pkt_systems_target=@CAI_TARGET_ID@
c_pkt_systems_url=https://github.com/sa6mwa/c.pkt.systems/releases/download/v@CAI_C_PKT_SYSTEMS_VERSION@/c.pkt.systems-@CAI_C_PKT_SYSTEMS_VERSION@-@CAI_TARGET_ID@.tar.gz
c_pkt_systems_sha256=@CAI_C_PKT_SYSTEMS_SHA256_FOR_PACKAGE@
dependency_mode=@CAI_RESOLVED_DEPENDENCY_MODE@

Name: cai
Description: C89/POSIX SDK client for the OpenAI Responses API
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lcai
Libs.private: -pthread @CAI_PC_DEPENDENCY_LIBS_PRIVATE@
Requires.private: @CAI_PACKAGE_REQUIRES_PRIVATE@
Cflags: -I${includedir} @CAI_PC_DEPENDENCY_CFLAGS@
