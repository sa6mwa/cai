@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(cai_DEPENDENCY_MODE "@CAI_RESOLVED_DEPENDENCY_MODE@")
set(cai_LOCKDC_SDK_VERSION "@CAI_LOCKDC_SDK_VERSION@")
set(cai_LOCKDC_SDK_TARGET "@CAI_TARGET_ID@")
set(cai_LOCKDC_SDK_URL
    "https://github.com/sa6mwa/liblockdc/releases/download/v@CAI_LOCKDC_SDK_VERSION@/liblockdc-@CAI_LOCKDC_SDK_VERSION@-@CAI_TARGET_ID@.tar.gz")
set(cai_LOCKDC_SDK_SHA256 "@CAI_LOCKDC_SDK_SHA256_FOR_PACKAGE@")

if(cai_DEPENDENCY_MODE STREQUAL "lockdc")
  find_dependency(lockdc CONFIG)
else()
  find_dependency(CURL)
endif()
find_dependency(Threads)

include("${CMAKE_CURRENT_LIST_DIR}/cai-targets.cmake")

set(_cai_dependency_includes "")
if(cai_DEPENDENCY_MODE STREQUAL "lockdc")
  if(TARGET lockdc::static)
    get_target_property(_cai_dependency_includes lockdc::static
                        INTERFACE_INCLUDE_DIRECTORIES)
  elseif(TARGET lockdc::shared)
    get_target_property(_cai_dependency_includes lockdc::shared
                        INTERFACE_INCLUDE_DIRECTORIES)
  endif()
else()
  find_path(cai_LONEJSON_INCLUDE_DIR lonejson.h
            HINTS "@CAI_CONFIG_LONEJSON_INCLUDE_HINT@")
  find_path(cai_PSLOG_INCLUDE_DIR pslog.h
            HINTS "@CAI_CONFIG_PSLOG_INCLUDE_HINT@")
  find_library(cai_LONEJSON_LIBRARY NAMES lonejson
               HINTS "@CAI_CONFIG_LONEJSON_LIBRARY_HINT@")
  if(NOT cai_LONEJSON_INCLUDE_DIR OR NOT cai_PSLOG_INCLUDE_DIR OR
     NOT cai_LONEJSON_LIBRARY)
    message(FATAL_ERROR
      "cai host dependency mode requires lonejson.h, pslog.h, and liblonejson")
  endif()
  list(APPEND _cai_dependency_includes
       "${cai_LONEJSON_INCLUDE_DIR}" "${cai_PSLOG_INCLUDE_DIR}")
endif()

foreach(_cai_target cai::cai_static cai::cai_shared)
  if(TARGET "${_cai_target}" AND _cai_dependency_includes)
    set_property(TARGET "${_cai_target}" APPEND PROPERTY
      INTERFACE_INCLUDE_DIRECTORIES "${_cai_dependency_includes}")
  endif()
endforeach()
if(NOT cai_DEPENDENCY_MODE STREQUAL "lockdc" AND TARGET cai::cai_static)
  set_property(TARGET cai::cai_static APPEND PROPERTY
    INTERFACE_LINK_LIBRARIES "${cai_LONEJSON_LIBRARY}")
endif()
unset(_cai_target)
unset(_cai_dependency_includes)
