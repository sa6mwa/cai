@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
set(cai_DEPENDENCY_MODE "@CAI_RESOLVED_DEPENDENCY_MODE@")
set(cai_C_PKT_SYSTEMS_VERSION "@CAI_C_PKT_SYSTEMS_VERSION@")
set(cai_C_PKT_SYSTEMS_TARGET "@CAI_TARGET_ID@")
set(cai_C_PKT_SYSTEMS_URL
    "https://github.com/sa6mwa/c.pkt.systems/releases/download/v@CAI_C_PKT_SYSTEMS_VERSION@/c.pkt.systems-@CAI_C_PKT_SYSTEMS_VERSION@-@CAI_TARGET_ID@.tar.gz")
set(cai_C_PKT_SYSTEMS_SHA256 "@CAI_C_PKT_SYSTEMS_SHA256_FOR_PACKAGE@")

find_dependency(CURL)
find_dependency(Threads)
find_dependency(lonejson CONFIG QUIET)
find_dependency(pslog CONFIG QUIET)

include("${CMAKE_CURRENT_LIST_DIR}/cai-targets.cmake")

set(_cai_dependency_includes "")
if(TARGET lonejson::lonejson)
  get_target_property(cai_LONEJSON_INCLUDE_DIR lonejson::lonejson
                      INTERFACE_INCLUDE_DIRECTORIES)
else()
  find_path(cai_LONEJSON_INCLUDE_DIR lonejson.h
            HINTS "@CAI_CONFIG_LONEJSON_INCLUDE_HINT@")
  find_library(cai_LONEJSON_LIBRARY NAMES lonejson
               HINTS "@CAI_CONFIG_LONEJSON_LIBRARY_HINT@")
  if(cai_LONEJSON_INCLUDE_DIR AND cai_LONEJSON_LIBRARY)
    add_library(lonejson::lonejson UNKNOWN IMPORTED)
    set_target_properties(lonejson::lonejson PROPERTIES
      IMPORTED_LOCATION "${cai_LONEJSON_LIBRARY}"
      INTERFACE_INCLUDE_DIRECTORIES "${cai_LONEJSON_INCLUDE_DIR}")
  endif()
endif()
if(TARGET pslog::pslog_shared)
  get_target_property(cai_PSLOG_INCLUDE_DIR pslog::pslog_shared
                      INTERFACE_INCLUDE_DIRECTORIES)
elseif(TARGET pslog::pslog_static)
  get_target_property(cai_PSLOG_INCLUDE_DIR pslog::pslog_static
                      INTERFACE_INCLUDE_DIRECTORIES)
else()
  find_path(cai_PSLOG_INCLUDE_DIR pslog.h
            HINTS "@CAI_CONFIG_PSLOG_INCLUDE_HINT@")
endif()
if(NOT cai_LONEJSON_INCLUDE_DIR OR NOT cai_PSLOG_INCLUDE_DIR OR
   NOT TARGET lonejson::lonejson)
  message(FATAL_ERROR
    "cai requires CURL, lonejson.h, pslog.h, and liblonejson. "
    "For native curl/OpenSSL dependencies, use ${cai_C_PKT_SYSTEMS_URL}.")
endif()
list(APPEND _cai_dependency_includes
     "${cai_LONEJSON_INCLUDE_DIR}" "${cai_PSLOG_INCLUDE_DIR}")

foreach(_cai_target cai::cai_static cai::cai_shared)
  if(TARGET "${_cai_target}" AND _cai_dependency_includes)
    set_property(TARGET "${_cai_target}" APPEND PROPERTY
      INTERFACE_INCLUDE_DIRECTORIES "${_cai_dependency_includes}")
  endif()
endforeach()
unset(_cai_target)
unset(_cai_dependency_includes)
